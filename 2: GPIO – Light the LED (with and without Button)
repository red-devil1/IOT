Experiment No.—2: GPIO – Light the LED (with and without Button) 

a) Blink LED using Python (Raspberry Pi) or C++ (Arduino) 
b) Add a push button to toggle LED ON/OFF

CODE
(a) Without Using Button 

import RPi.GPIO as GPIO 
import time 
LED_PIN = 17  # GPIO17 (BCM numbering) 
GPIO.setmode(GPIO.BCM)      # Use BCM pin numbering 
GPIO.setup(LED_PIN, GPIO.OUT) 
try: 
    while True: 
        GPIO.output(LED_PIN, GPIO.HIGH)  # LED ON 
        time.sleep(1)                    # Wait 1 second 
        GPIO.output(LED_PIN, GPIO.LOW)   # LED OFF 
        time.sleep(1)                    # Wait 1 second 
except KeyboardInterrupt: 
    print("Program stopped") 

finally: 
    GPIO.cleanup()  # Reset GPIO settings 


(b) With Using Button 

import RPi.GPIO as GPIO 
import time 
 
LED = 17 
BUTTON = 27 
 
GPIO.setmode(GPIO.BCM) 
GPIO.setup(LED, GPIO.OUT) 
GPIO.setup(BUTTON, GPIO.IN, pull_up_down=GPIO.PUD_UP) 
 
led_state = False 
 
try: 
    while True: 
        if GPIO.input(BUTTON) == GPIO.LOW:  # Button pressed 
            led_state = not led_state 
            GPIO.output(LED, led_state) 
            time.sleep(0.3)  # debounce delay 
 
except KeyboardInterrupt: 
    GPIO.cleanup()
